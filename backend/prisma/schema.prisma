generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume       Resume?
  applications Application[]
  analysis     Analysis?     // NEW: latest analysis report
}

model Resume {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String?
  email     String?
  phone     String?
  location  String?
  linkedin  String?
  github    String?
  portfolio String?

  skills     Json?
  experience Json?
  education  Json?
  projects   Json?

  rawText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ApplicationStatus {
  SAVED
  APPLIED
  IN_CONTACT
  INTERVIEWING
  REJECTED
  OFFER
}

model Application {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  company            String
  role               String
  location           String?
  experienceRequired String?
  sourceUrl          String?
  description        String?
  skillsRequired     Json?

  status      ApplicationStatus @default(SAVED)
  matchScore  Int?
  appliedDate DateTime?
  position    Int               @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

// NEW MODEL — caches the latest AI-generated report
model Analysis {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Whole report stored as JSON — flexible to evolve without migrations
  report Json

  // Quick stats we compute outside AI (also useful for the UI)
  callbackRate    Float?  // applied → got_callback ratio
  totalApplied    Int?
  totalCallbacks  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}